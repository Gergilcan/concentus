# Copy to .env and fill in real values. Never commit .env with real secrets.

# --- Claude auth (docker-compose backend service) ---------------------------
# Subscription token from `claude setup-token` (NOT an API key). Preferred way to run
# the backend against your Claude subscription in docker-compose.
CLAUDE_CODE_OAUTH_TOKEN=

# Cloud (Managed Agents) API key. Set this instead of CLAUDE_CODE_OAUTH_TOKEN to run
# flows via Anthropic's hosted API rather than the local `claude` CLI.
ANTHROPIC_API_KEY=

# Execution mode: auto (default; key set -> cloud, else local) | local | api-key.
ANTHROPIC_AUTH_MODE=auto

# Alternative to ANTHROPIC_API_KEY understood by AnthropicClientProvider.
ANTHROPIC_AUTH_TOKEN=

# --- Run persistence (PostgreSQL) --------------------------------------------
# docker-compose ships a `db` service and wires these automatically; the value below is only
# the password it starts with. Change it, or leave it for local use.
# The backend creates its own schema, so an empty database is all that's needed.
PERSIST_DB_PASSWORD=concentus

# To use a hosted database (Neon, RDS, Cloud SQL) instead, remove the `db` service from
# docker-compose.yml and set all three:
# PERSIST_DB_URL=jdbc:postgresql://ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require
# PERSIST_DB_USER=neondb_owner
# PERSIST_DB_PASSWORD=...
# Set PERSIST_ENABLED=false to run without persistence (runs are lost on restart).

# --- Other model providers (the "api" backend) --------------------------------
# A flow names only a model; the provider follows from the model-id prefix.
# A provider with no key is not registered, so naming its model fails at launch
# with a clear message rather than mid-run.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
# Vertex AI: project + region + OAuth token (gcloud auth print-access-token)
VERTEX_PROJECT=
VERTEX_REGION=us-central1
VERTEX_ACCESS_TOKEN=
# Any other OpenAI-shaped vendor: id|baseUrl|apiKey (comma-separated).
# e.g. groq|https://api.groq.com/openai/v1|gsk-...,ollama|http://localhost:11434/v1|
LLM_OPENAI_COMPATIBLE=
# Extra model-id routing: prefix:providerId (comma-separated, longest match wins).
LLM_MODEL_PREFIXES=

# --- Backend runtime (apps/backend/src/main/resources/application.properties) ---
# Directory where flows, run data, etc. are persisted.
APP_DATA_DIR=./data

# Path/name of the local `claude` CLI binary (blank = resolved from PATH).
CLAUDE_COMMAND=claude

# Permission mode passed to the local claude CLI executor.
CLAUDE_PERMISSION_MODE=bypassPermissions

# Auto-register flow MCP nodes into `claude mcp add` (user scope) at run time.
LOCAL_AUTO_REGISTER_MCP=true

# Directories an agent's "Context folders" may point inside (comma-separated).
# Required: while this is empty every context folder is rejected, so a deployment
# that never opts in cannot be told to read arbitrary host paths.
# e.g. LOCAL_CONTEXT_ROOTS=C:\Users\me\code   (or /home/me/code)
LOCAL_CONTEXT_ROOTS=

# Directory for the reusable agent YAML library; blank = <APP_DATA_DIR>/agents.
APP_AGENTS_DIR=

# --- Example per-node resource credentials -----------------------------------
# These are just the conventional env var names used in example flows/specs
# (apps/backend/src/main/resources/agent.example.yaml) — a flow node's `tokenEnv`/
# `passwordEnv` field can point at any env var name you choose.

# Bearer token for a repository node's Git provider (GitHub example).
GITHUB_TOKEN=

# Bearer token for an MCP server node (GitHub MCP example).
GITHUB_MCP_TOKEN=

# Password for a SQL RAG source node's JDBC connection (Postgres example).
PGPASSWORD=
